{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mantella",
  "version": "0.1.0",
  "identifier": "io.bearrr.mantella",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mantella",
        "width": 1280,
        "height": 860,
        "minWidth": 760,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "trafficLightPosition": { "x": 14, "y": 26 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' mantella: http://mantella.localhost https://mantella.localhost data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "mimeType": "application/pdf",
        "description": "PDF Document",
        "role": "Viewer"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/pdfium/": "pdfium/"
    }
  }
}
